---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
    const entries = await getCollection('goods');
    return entries.map( entry => ({
        params: { slug: entry.id }, 
        props: { entry },
    }));
}

interface Props {
  entry: CollectionEntry<'goods'>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title}>
  <h1>{entry.data.title}</h1>
  <p style="opacity: 0.7;"><em>{entry.data.description}</em></p>
  <hr />
  <div class="goods-content">
    <Content />
  </div>
</BaseLayout>

<style is:global>
  /* styles markdown rendered inside the goods-content div */
  .goods-content h2 { color: var(--accent); margin-top: 2rem; }
  .goods-content h3 { color: var(--text); opacity: 0.9; }
  .goods-content ul { list-style-type: none; padding-left: 15px; border-left: 1px solid #aef7e3; }
  .goods-content li { margin-bottom: 8px; }
  .goods-content a { font-weight: bold; }
</style>