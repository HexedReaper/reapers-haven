---
// /goods/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const base = import.meta.env.BASE_URL || '';

const allGoods = await getCollection('goods');
const sortedGoods = allGoods.sort((a, b) => a.data.title.localeCompare(b.data.title));
---

<BaseLayout title="All Goods">
  <div class="index-content" data-view="list">
    <h1>The Goods Archive</h1>
    <p>Links, software, and other goods</p>
    <hr />

    <div class="index-toolbar">
      <button data-view="list" title="List view" aria-label="Switch to list view">
        <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="2" rx="1"/><rect x="3" y="11" width="18" height="2" rx="1"/><rect x="3" y="18" width="18" height="2" rx="1"/></svg>
      </button>
      <button data-view="cards" title="Cards view" aria-label="Switch to cards view">
        <svg viewBox="0 0 24 24"><rect x="3" y="3" width="8" height="8" rx="1.5"/><rect x="13" y="3" width="8" height="8" rx="1.5"/><rect x="3" y="13" width="8" height="8" rx="1.5"/><rect x="13" y="13" width="8" height="8" rx="1.5"/></svg>
      </button>
    </div>

    <ul>
      {sortedGoods.map((good) => (
        <li>
          <a href={`${base}/goods/${good.id}`}>
            {good.data.title}
            <span>{good.data.description}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>

  <script is:inline>
  (function() {
    var c = document.querySelector('.index-content');
    if (!c) return;
    var saved = localStorage.getItem('index-view') || 'list';
    c.setAttribute('data-view', saved);
    document.querySelectorAll('.index-toolbar button').forEach(function(b) {
      b.classList.toggle('active', b.dataset.view === saved);
      b.addEventListener('click', function() {
        var v = b.dataset.view;
        c.setAttribute('data-view', v);
        localStorage.setItem('index-view', v);
        document.querySelectorAll('.index-toolbar button').forEach(function(x) {
          x.classList.toggle('active', x.dataset.view === v);
        });
      });
    });
  })();
  </script>
</BaseLayout>