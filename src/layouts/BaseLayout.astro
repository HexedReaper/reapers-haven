---
// BaseLayout.astro
import { getCollection } from 'astro:content';
import '../styles/global.css';
import kaomojiData from '../data/kaomojis.json';

const { title } = Astro.props;
const base = (import.meta.env.BASE_URL || '').replace(/\/+$/, '');
function getRandomKaomoji(category) {
  const list = kaomojiData[category];
  if (!list || list.length === 0) return '•_•';
  const randomIndex = Math.floor(Math.random() * list.length);
  return list[randomIndex];
}

---
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title} | Reaper's Haven</title>

</head>
<body>
   <nav class="main-nav">
        {
            (Astro.url.pathname.startsWith(`${base}/tutorials`) || 
             Astro.url.pathname.startsWith(`${base}/goods`)) && 
             !Astro.url.pathname.startsWith(`${base}/goods/updates`) ? (
                <button id="nav-left-toggle" class="nav-sidebar-toggle left-toggle">[☰ GUIDES]</button>
            ) : null
        }

        <a href={`${base}/`} class={Astro.url.pathname === `${base}/` ? 'active-nav-link' : ''}>[home]</a>
        <a href={`${base}/tutorials`} class={Astro.url.pathname.startsWith(`${base}/tutorials`) ? 'active-nav-link' : ''}>[ALL TUTORIALS]</a>
        <a href={`${base}/goods`} class={(Astro.url.pathname === `${base}/goods` || Astro.url.pathname === `${base}/goods/`) ? 'active-nav-link' : ''}>[ALL GOODS]</a>
        <a href={`${base}/goods/updates/`} class={Astro.url.pathname === `${base}/goods/updates/` ? 'active-nav-link' : ''}>[ALL UPDATES]</a>

        <button id="open-search-btn">[SEARCH]</button>

        <button id="toggle-telemetry-btn" class="telemetry-toggle">
            [ISSUE REPORT: ON]
        </button>
        
        {
            (Astro.url.pathname.startsWith(`${base}/tutorials`) || 
             Astro.url.pathname.startsWith(`${base}/goods`)) && 
             !Astro.url.pathname.startsWith(`${base}/goods/updates`) ? (
                <button id="nav-right-toggle" class="nav-sidebar-toggle right-toggle">[ON THIS PAGE ▷]</button>
            ) : null
        }
        <hr />
    </nav>

    <!-- SEARCH MODAL  -->
    <dialog id="search-modal" data-base={base + '/'}>
      <div class="modal-content">
        <div class="search-modal-header">
          <span class="search-modal-title">/search</span>
          <span class="search-modal-shortcut">Ctrl+K</span>
          <button class="close-btn" id="close-search-btn">[X]</button>
        </div>
        <div class="search-input-wrapper">
          <span class="search-input-prefix">&gt;</span>
          <input type="text" id="search-input" placeholder="type to search..." />
          <span id="result-count" class="result-count"></span>
        </div>
        <ul id="search-results" class="clean-list"></ul>
      </div>
    </dialog>


    <slot />
    
</body>

<script>
    import "../scripts/search";
    document.addEventListener('DOMContentLoaded', () => {
        // ==========================================
        // SIDEBAR TOGGLE MECHANICS (FIXED FOR MOBILE)
        // ==========================================
        const layout = document.getElementById('sidebar-layout');
        const leftToggle = document.getElementById('nav-left-toggle');
        const rightToggle = document.getElementById('nav-right-toggle');

        // Toggle Left Sidebar
        leftToggle?.addEventListener('click', (e) => {
            e.stopPropagation(); // Prevents the click from instantly closing via the main-content listener below
            layout?.classList.toggle('left-collapsed');
            layout?.classList.remove('right-collapsed'); // Close the other sidebar to keep screen clean
        });

        // Toggle Right Sidebar
        rightToggle?.addEventListener('click', (e) => {
            e.stopPropagation(); // Prevents the click from instantly closing via the main-content listener below
            layout?.classList.toggle('right-collapsed');
            layout?.classList.remove('left-collapsed');  // Close the other sidebar to keep screen clean
        });

        // Swipe/Click away sidebars on main content unfocus
        document.querySelector('.main-content')?.addEventListener('click', () => {
            if (window.innerWidth < 1280) { // 80rem = 1280px
                layout?.classList.remove('left-collapsed', 'right-collapsed');
            }
        });

        // ==========================================
        // CODEBLOCK COPY BUTTONS
        // ==========================================
        const codeBlocks = document.querySelectorAll('pre'); 

        codeBlocks.forEach((block) => {
            const button = document.createElement('button');
            button.className = 'copy-btn';
            button.innerText = 'COPY';
            block.appendChild(button);

            let resetTimeout; 

            button.addEventListener('click', async () => {
                const code = block.querySelector('code')?.innerText || '';
                
                try {
                    await navigator.clipboard.writeText(code);
                    button.innerText = 'COPIED!';
                    button.style.background = 'var(--accent)';
                    button.style.color = 'var(--bg)';

                    clearTimeout(resetTimeout);

                    resetTimeout = setTimeout(() => {
                        button.innerText = 'COPY';
                        button.style.background = 'transparent';
                        button.style.color = 'var(--accent)';
                    }, 2000);
                }
                catch (err) {
                    console.error('Failed to copy text: ', err);
                    button.innerText = 'ERROR';
                }
            });
        });
    });
</script>

</html> 