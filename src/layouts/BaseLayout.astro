---
const { title } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title} | Reaper's Haven</title>

    <style is:global>
        :root{
            --bg: rgb(28, 29, 47);
            --text: rgb(192, 251, 226);
            --accent: rgb(96, 247, 129);
        }

        body{
            background: var(--bg);
            color: var(--text);
            font-family: 'JetBrains Mono', monospace;
            max-width: 800px;
            margin: 40px auto;
            padding:  0 20px;
            line-height: 1.6;
        }

        a{
            color: var(--accent);
            text-decoration: none;
        }

        a:hover{
            text-decoration: underline;
        }

        hr{
            border: 0;
            border-top: 1px solid var(--text);
        }

        input[type="text"]{
            background: transparent;
            color: var(--text);
            padding: 8px 14px;
            outline: none;
            border: 1px solid var(--text);

        }
        input[type="text"]:focus{
            border: 1px solid var(--accent);
        }

        button{
            background: transparent;
            color: var(--accent);
            border: none;
            cursor: pointer;            
        }
        button:hover{
            text-decoration: underline;
        }

        /* img base style*/
        img {
            max-width: 100%;
            border-radius: 15px;
            height: auto;
            display: block;
            margin: 2rem 0;
            opacity: 0.85;
            filter: drop-shadow(0 0 2px rgba(192, 251, 226, 0.15));
            transition: all 0.3s ease;
        }

        /* img desktop hover*/
        @media (hover: hover) and (pointer: fine) {
            img:hover {
                opacity: 1;
                filter: drop-shadow(0 0 15px rgba(96, 247, 129, 0.4));
                transform: translateY(-2px);
            }
        }

        /* phones */
        @media (max-width: 600px) {
            img {
                margin: 1.5rem 0;
                border-radius: 10px;
                opacity: 0.95;
            }
            
            img:active {
                opacity: 1;
                filter: drop-shadow(0 0 10px rgba(96, 247, 129, 0.5));
                transform: scale(0.98); 
            }

        }

    </style>

</head>
<body>
    <nav>
        <a href=`${base}/`>[home]</a>
        <hr />
    </nav>
    <slot />
    
</body>
</html>